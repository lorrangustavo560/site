# Copie este arquivo para .env e preencha com seus dados do Supabase.
VITE_SUPABASE_URL=https://SEU_PROJETO.supabase.co
VITE_SUPABASE_ANON_KEY=SUA_CHAVE_ANON_PUBLICA

# Deixe false para rodar com geração local de demonstração.
# Use true se você criar uma Supabase Edge Function chamada generate-campaign.
VITE_USE_AI_FUNCTION=false
